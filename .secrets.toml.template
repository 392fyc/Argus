# Argus — Secrets Template
# Copy this file to .secrets.toml and fill in your values.
# NEVER commit .secrets.toml to version control.

[openai]
key = ""  # Your OpenAI API key (sk-...)

[github]
# GitHub App credentials (for webhook mode)
app_id = ""          # GitHub App ID (numeric)
webhook_secret = ""  # Random string used to verify webhook payloads

# The private key from your GitHub App (.pem file contents)
# Paste the FULL key including BEGIN/END lines.
# Use triple-quotes for multiline:
private_key = """\
-----BEGIN RSA PRIVATE KEY-----
PASTE_YOUR_KEY_HERE
-----END RSA PRIVATE KEY-----\
"""

# For polling mode: use a personal access token instead of GitHub App
user_token = ""  # ghp_... (only needed for polling mode)
