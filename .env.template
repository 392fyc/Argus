# Argus — Environment Variables
# Copy this file to .env and fill in your values.

# Port for the PR-Agent webhook server (default: 3000)
PR_AGENT_PORT=3000

# Cloudflare Tunnel token (for webhook mode only)
# Get this from: https://dash.teams.cloudflare.com/ -> Access -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# User whitelist — comma-separated GitHub usernames (case-insensitive).
# Only these users can trigger Argus reviews via PR comments.
# Leave empty to allow ALL users.
ARGUS_ALLOWED_USERS=392fyc
